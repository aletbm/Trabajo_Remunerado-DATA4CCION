        - id: 63d9c6f3a37c431db487b59cc0a4b652
          blockGroup: c808c9aacc0d44dca3178acf47b74109
          sortingKey: "000018"
          contentHash: 58b9c922
          executionCount: 10
          executionFinishedAt: 2026-04-10T22:07:04.463Z
          executionStartedAt: 2026-04-10T22:07:04.462Z
          type: code
          content: >-
            # Estandarización de la columna 'pais' para garantizar consistencia en la clave de unión.

            # Se eliminan espacios, se unifica el formato en mayúsculas y se remueven acentos.

            resultado_final['pais'] = (
                resultado_final['pais']
                .str.strip()
                .str.upper()
                .str.normalize('NFKD')
                .str.encode('ascii', errors='ignore')
                .str.decode('utf-8')
            )


            # Mostrar resultados

            resultado_final['pais'].unique()
          metadata:
            execution_start: 1775858824462
