            # Definimos diccionario de reemplazos al español

            dicc_paises= {
                'Argentina': 'Argentina',
                'Chile': 'Chile',
                'Colombia': 'Colombia',
                'Costa Rica': 'Costa Rica',
                'Dominican Republic': 'Republica Dominicana', 
