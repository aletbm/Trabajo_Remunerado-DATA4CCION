            # Transformación a formato ancho: cada tipo de trabajo pasa a ser una columna

            # para obtener una única fila por país


            df_tiempo_trabajo = tiempo_trabajo_copia.pivot(
                index='pais',
                columns='tipo_trabajo',
                values='promedio_horas_semanales'
            ).reset_index()


            # Eliminación del nombre del eje de columnas para mayor claridad

            df_tiempo_trabajo.columns.name = None


            # Recuperación de columnas constantes por país (indicador y anios)

            df_extra = tiempo_trabajo_copia[['pais', 'indicador', 'anios']].drop_duplicates()


            df_tiempo_trabajo = df_tiempo_trabajo.merge(df_extra, on='pais', how='left')


            # Limpieza de nombres de columnas

            df_tiempo_trabajo = df_tiempo_trabajo.rename(
                columns=
                {'Tiempo total de trabajo': 'tiempo_total_trabajo',
                'Tiempo trabajo remunerado': 'tiempo_trabajo_remunerado',
                'Tiempo trabajo no remunerado': 'tiempo_trabajo_no_remunerado'
                }
            )


            # Aplicamos orden de columnas correcto

            df_tiempo_trabajo = df_tiempo_trabajo[
                ['indicador', 'anios', 'pais', 'tiempo_total_trabajo', 'tiempo_trabajo_remunerado', 'tiempo_trabajo_no_remunerado']
            ]


            # Verificación del resultado

