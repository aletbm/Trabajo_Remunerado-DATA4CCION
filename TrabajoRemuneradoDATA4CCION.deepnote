          content: df_poblacion.dtypes
          metadata:
            execution_start: 1775859014833
            execution_millis: 0
            execution_context_id: 92f48a46-2b60-4dd0-9ce9-c0ec91cb27cf
        - id: adb2dbb4743a457eb06366b89256b0d6
          blockGroup: 79c82e73819d4ab6a09ae8eba6791c39
          sortingKey: "000058"
          contentHash: c5644c1f
          executionCount: 41
          executionFinishedAt: 2026-04-10T22:08:38.173Z
          executionStartedAt: 2026-04-10T22:08:38.173Z
          type: code
          content: >-
            # Copias para el merge final (no se modifican los datasets del ETL)

            df_poblacion = poblacion_filtrada.copy()

            df_tiempo = df_tiempo_trabajo.copy()

            df_internet = resultado_final.copy()


            # Eliminación de columnas innecesarias SÓLO para la fase de merge

            df_poblacion = df_poblacion.drop(columns=["indicador", "anios"])

            df_tiempo = df_tiempo.drop(columns=["indicador", "anios"])

            df_internet = df_internet.drop(columns=["anio", "edad"])


            # ---------------------------------------------------

            # DATASET 1: TIEMPO + INTERNET (nivel país)

            # ---------------------------------------------------

            df_tiempo_internet = df_tiempo.merge(df_internet, on="pais", how="left")


            # ---------------------------------------------------

            # DATASET 2: POBLACIÓN (nivel país + edad + cantidad de personas)

            # ---------------------------------------------------

            orden_edades = [
                "0-4", "5-9", "10-14", "15-19", "20-24",
                "25-29", "30-34", "35-39", "40-44", "45-49",
                "50-54", "55-59", "60-64", "65-69", "70-74",
                "75-79", "80-84", "85-89", "90-94", "95-99",
                "100 y más"
            ]


            df_poblacion["grupos_edad"] = pd.Categorical(
                df_poblacion["grupos_edad"],
                categories=orden_edades,
                ordered=True
            )


            df_poblacion = df_poblacion.sort_values(by=["pais", "grupos_edad"])
          metadata:
            execution_start: 1775858918173
            execution_millis: 0
            execution_context_id: 92f48a46-2b60-4dd0-9ce9-c0ec91cb27cf
