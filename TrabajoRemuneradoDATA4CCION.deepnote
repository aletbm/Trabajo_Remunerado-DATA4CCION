          type: code
          content: >-
            from google.colab import userdata

            import os


            # Obtener token desde Colab Secrets

            GITHUB_TOKEN = userdata.get('GITHUB_TOKEN')

            GITHUB_USER = userdata.get('GITHUB_USER')

            REPO_NAME = "Trabajo_Remunerado-DATA4CCION"


            # Pasar variables a entorno del shell

            os.environ['GITHUB_TOKEN'] = GITHUB_TOKEN

            os.environ['GITHUB_USER'] = GITHUB_USER

            os.environ['REPO_NAME'] = REPO_NAME


            # Configurar git

            !git config --global user.email "$GITHUB_USER@users.noreply.github.com"

            !git config --global user.name "$GITHUB_USER"


            # Clonar repo

            !git clone https://$GITHUB_TOKEN@github.com/$GITHUB_USER/$REPO_NAME.git


            # Copiar PARQUETs

            !mkdir -p $REPO_NAME/data

            !cp *.parquet $REPO_NAME/data/


            # Push

            %cd $REPO_NAME

            !git add data/*.parquet

            !git commit -m "Add raw data PARQUETs"

            !git push https://$GITHUB_TOKEN@github.com/$GITHUB_USER/$REPO_NAME.git

            %cd /content

            !rm -rf $REPO_NAME
